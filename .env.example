# --- HTTP server ---
RL_PORT=8080

# --- Redis ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=50
REDIS_DIAL_TIMEOUT_MS=200
REDIS_READ_TIMEOUT_MS=100

# --- Algorithm ---
RL_SCHEME=token_bucket          # only token_bucket implemented this iteration

# --- Token bucket limits ---
RL_BUCKET_CAPACITY=100          # burst ceiling
RL_REFILL_RATE=10               # tokens per second

# --- Behavior ---
RL_FAIL_MODE=closed             # open | closed (verdict on Redis failure)
RL_KEY_PREFIX=rl
